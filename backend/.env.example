# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend Email
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=noreply@millenium.co.ke

# Server
PORT=3000
NODE_ENV=production

# Frontend URLs (for CORS) - both on same custom domain
FRONTEND_URL=https://admin.millenium.co.ke
HR_FRONTEND_URL=https://admin.millenium.co.ke
